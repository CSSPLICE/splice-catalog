<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') -%>
<%- include('../partials/header') -%>

<body>
  <style>
    #issues-list { line-height: 1.1; }
    #issues-list p { margin: 0; }
    #issues-list li { padding-bottom: 1em; }
  </style>
  <div class="container">
    <h2>Validation Results</h2>
    <p class="text-muted" style="font-size: 0.85em;">Job: <%= uuid %></p>
    <p>
      processed: <span id="processed-count"><%= processed %></span>/<span id="total-count"><%= total %></span>
      &nbsp;saved: <span id="saved-count"><%= saved %></span>
      &nbsp;updated: <span id="updated-count"><%= updated %></span>
      <span id="status-indicator"
        <% if (status === 'processing') { %>class="spinner-border spinner-border-sm" role="status" aria-hidden="true"<% } else if (status === 'complete') { %>style="color: green; font-weight: bold;" aria-label="Complete"<% } else { %>style="color: red; font-weight: bold;" aria-label="Failed"<% } %>><% if (status === 'complete') { %>✓<% } else if (status === 'failed') { %>✗<% } %></span>
    </p>
    <h3 id="issues-heading"<% if (errors.length === 0) { %> style="display:none"<% } %>>Issues:</h3>
    <ul id="issues-list">
      <% errors.forEach(function (item) { %>
        <li>
          <p>Persistent ID: <%= item.persistentID %></p>
          <p>Property: <%= item.property %></p>
          <% for (const constraint in item.constraints) { %>
            <%
              const message = item.constraints[constraint].message;
              const severity = item.constraints[constraint].severity;
              const color = severity === 'warning' ? 'orange' : severity === 'notice' ? 'grey' : 'red';
            %>
            <p style="color: <%= color %>">
              <%= constraint %> - <%= message %>
            </p>
          <% } %>
        </li>
      <% }); %>
    </ul>
  </div>

  <% if (live) { %>
  <script>
    (function () {
      var uuid = <%- JSON.stringify(uuid) %>;

      function appendError(item) {
        var heading = document.getElementById('issues-heading');
        if (heading) heading.style.display = '';
        var list = document.getElementById('issues-list');
        if (!list) return;
        var li = document.createElement('li');
        var idP = document.createElement('p');
        idP.textContent = 'Persistent ID: ' + item.persistentID;
        var propP = document.createElement('p');
        propP.textContent = 'Property: ' + item.property;
        li.appendChild(idP);
        li.appendChild(propP);
        for (var name in item.constraints) {
          var c = item.constraints[name];
          var p = document.createElement('p');
          p.style.color = c.severity === 'warning' ? 'orange' : c.severity === 'notice' ? 'grey' : 'red';
          p.textContent = name + ' - ' + c.message;
          li.appendChild(p);
        }
        list.appendChild(li);
      }

      function setCount(id, value) {
        var el = document.getElementById(id);
        if (el && typeof value === 'number') el.textContent = value;
      }

      function applyTerminal(status) {
        var indicator = document.getElementById('status-indicator');
        if (!indicator) return;
        indicator.className = '';
        indicator.removeAttribute('role');
        indicator.removeAttribute('aria-hidden');
        if (status === 'complete') {
          indicator.style.color = 'green';
          indicator.style.fontWeight = 'bold';
          indicator.setAttribute('aria-label', 'Complete');
          indicator.textContent = '✓';
        } else {
          indicator.style.color = 'red';
          indicator.style.fontWeight = 'bold';
          indicator.setAttribute('aria-label', 'Failed');
          indicator.textContent = '✗';
        }
      }

      var es = new EventSource('/review/' + encodeURIComponent(uuid) + '/sse');

      es.addEventListener('snapshot', function (e) {
        var d = JSON.parse(e.data);
        setCount('total-count', d.total);
        setCount('processed-count', d.processed);
        setCount('saved-count', d.saved);
        setCount('updated-count', d.updated);
      });

      es.addEventListener('update', function (e) {
        var d = JSON.parse(e.data);
        setCount('total-count', d.total);
        setCount('processed-count', d.processed);
        setCount('saved-count', d.saved);
        setCount('updated-count', d.updated);
        if (d.newErrors && d.newErrors.length) d.newErrors.forEach(appendError);
      });

      es.addEventListener('terminal', function (e) {
        var d = JSON.parse(e.data);
        applyTerminal(d.status);
        es.close();
      });

      es.onerror = function () {
        // Server closed (job already terminal or gone). Stop reconnect attempts.
        es.close();
      };
    })();
  </script>
  <% } %>

  <%- include('../partials/footer') -%>
</body>
</html>